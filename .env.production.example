# Copy to the server as .env (never commit .env)
#   cp .env.production.example .env && nano .env

POSTGRES_USER=renovessa
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_DB=renovessa

# openssl rand -base64 32
AUTH_SECRET=change-me-long-random-auth-secret

NEXT_PUBLIC_APP_URL=https://renovessa.com
PORT=7090

# First deploy only: set true to load demo seed, then set false and redeploy
RUN_SEED=false

# Twilio (agent calling) — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Voice SDK (browser softphone)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=

# SendGrid (agent email) — https://app.sendgrid.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=ops@renovessa.com
SENDGRID_FROM_NAME=Renovessa Ops
