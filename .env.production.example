# Copy to the server as .env (never commit .env)
#   cp .env.production.example .env && nano .env

POSTGRES_USER=renovessa
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_DB=renovessa

# openssl rand -base64 32
AUTH_SECRET=change-me-long-random-auth-secret

NEXT_PUBLIC_APP_URL=https://renovessa.com
PORT=7090

# First deploy only: set true to load demo seed, then set false and redeploy
RUN_SEED=false
