generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HOMEOWNER
  CONTRACTOR
  SUPER_ADMIN
  OPS_AGENT
  SCHEDULER
  FINANCE_MANAGER
  OPS_MANAGER
  QA_MANAGER
  CONTRACTOR_ACQUISITION
}

enum LeadStatus {
  NEW
  ASSIGNED
  CALLING
  QUALIFICATION_IN_PROGRESS
  QUALIFIED
  UNQUALIFIED
  SCHEDULING
  APPOINTMENT_OFFERED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_COMPLETED
  HOMEOWNER_CONFIRMED
  BILLING_PENDING
  BILLING_APPROVED
  DISPUTED
  CLOSED
  RECYCLE
}

enum AppointmentStatus {
  OFFERED
  ACCEPTED
  DECLINED
  SCHEDULED
  REMINDER_SENT
  IN_PROGRESS
  CHECKED_IN
  COMPLETED
  HOMEOWNER_CONFIRMED
  NO_SHOW
  DISPUTED
  BILLED
  CANCELLED
}

enum ContractorTier {
  TRIAL
  STANDARD
  PREFERRED
  WATCH
  SUSPENDED
  BANNED
}

enum CapacityCellStatus {
  OPEN
  TESTING
  FULL
  WAITLIST
  PAUSED
  UNDERPERFORMING
  EXPANSION_CANDIDATE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
}

enum DisputeOutcome {
  BILL_STANDS
  FULL_CREDIT
  PARTIAL_CREDIT
  RESCHEDULE
  CONTRACTOR_WARNING
}

enum InvoiceStatus {
  PENDING
  APPROVED
  CHARGED
  FAILED
  CREDITED
  REFUNDED
}

enum AuditEventType {
  FORM_SUBMITTED
  CONSENT_RECORDED
  SMS_SENT
  CALL_MADE
  QUALIFICATION_DECISION
  CONTRACTOR_OFFERED
  CONTRACTOR_ACCEPTED
  CONTRACTOR_DECLINED
  CALENDAR_INVITE_SENT
  REMINDER_SENT
  CHECK_IN_RECORDED
  HOMEOWNER_CONFIRMED
  BILLING_TRIGGER
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  STATUS_CHANGED
  NOTE_ADDED
  CREDIT_ISSUED
  EMAIL_SENT
  EMAIL_REPLIED
  CAMPAIGN_SENT
}

enum CaseStudyStatus {
  DRAFT
  FINAL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         UserRole
  isDemo       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contractorProfile  ContractorProfile?
  projectRequests    ProjectRequest[]    @relation("HomeownerProjects")
  assignedLeads      ProjectRequest[]    @relation("AssignedAgent")
  auditEvents        AuditEvent[]        @relation("AuditActor")
  notifications      Notification[]
  approvedInvoices   Invoice[]           @relation("ApprovedBy")
  twilioPhoneNumbers TwilioPhoneNumber[] @relation("AssignedAgentNumbers")
  callLogs           CallLog[]           @relation("AgentCalls")
  emailMessages      EmailMessage[]      @relation("AgentEmails")
  emailCampaigns     EmailCampaign[]     @relation("CampaignOwner")
}

model ContractorProfile {
  id                      String         @id @default(cuid())
  userId                  String         @unique
  companyName             String
  trade                   String
  tier                    ContractorTier @default(TRIAL)
  status                  String         @default("active")
  licenseVerified         Boolean        @default(false)
  insuranceVerified       Boolean        @default(false)
  yearsInBusiness         Int?
  employeeCount           Int?
  avgJobSize              String?
  serviceZips             String[]
  showRate                Float          @default(100)
  acceptanceRate          Float          @default(100)
  disputeRate             Float          @default(0)
  contactPerson           String?
  availabilityNotes       String?
  pilotTerms              String?
  firstAppointmentPricing String?        @default("free")
  pilotPriceAmount        Float?
  responseTimeHours       Int?
  googleBusinessUrl       String?
  internalNotes           String?
  isDemo                  Boolean        @default(false)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  capacityCells CapacityCell[] @relation("CellContractors")
  invoices      Invoice[]
  disputes      Dispute[]
  callLogs      CallLog[]
  emailMessages EmailMessage[]
}

model CapacityCell {
  id               String             @id @default(cuid())
  name             String
  trade            String
  zipCluster       String[]
  jobSizeMin       Int?
  jobSizeMax       Int?
  maxSlots         Int                @default(2)
  appointmentLimit Int                @default(20)
  status           CapacityCellStatus @default(OPEN)
  isDemo           Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  contractors ContractorProfile[] @relation("CellContractors")
}

model ProjectRequest {
  id                          String     @id @default(cuid())
  referenceNumber             String     @unique
  homeownerId                 String?
  assignedAgentId             String?
  firstName                   String
  lastName                    String
  email                       String
  phone                       String
  zipCode                     String
  trade                       String
  description                 String
  urgency                     String
  budgetRange                 String
  preferredContact            String?
  tcpaConsent                 Boolean    @default(false)
  status                      LeadStatus @default(NEW)
  source                      String     @default("organic")
  qualificationNotes          String?
  disposition                 String?
  address                     String?
  ownershipAuthority          String?
  preferredAppointmentWindows String?
  photoUrls                   String[]
  serviceCellMatch            Boolean?
  invalidReason               String?
  reachable                   Boolean?
  isDemo                      Boolean    @default(false)
  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt

  homeowner     User?          @relation("HomeownerProjects", fields: [homeownerId], references: [id])
  assignedAgent User?          @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  appointment   Appointment?
  auditEvents   AuditEvent[]
  dispute       Dispute?
  caseStudy     CaseStudy?
  callLogs      CallLog[]
  emailMessages EmailMessage[]
}

model Appointment {
  id                     String            @id @default(cuid())
  projectRequestId       String            @unique
  contractorId           String
  scheduledAt            DateTime?
  acceptedAt             DateTime?
  checkedInAt            DateTime?
  homeownerConfirmedAt   DateTime?
  status                 AppointmentStatus @default(OFFERED)
  calendarInviteSent     Boolean           @default(false)
  billingTriggered       Boolean           @default(false)
  billingApproved        Boolean           @default(false)
  amount                 Float?
  location               String?
  homeownerPreConfirmed  Boolean           @default(false)
  contractorPreConfirmed Boolean           @default(false)
  estimateGiven          String?
  contractorOutcomeNotes String?
  homeownerOutcomeNotes  String?
  followUpRequired       Boolean           @default(false)
  opportunitySentAt      DateTime?
  declineReason          String?
  pilotBillableReason    String?
  isDemo                 Boolean           @default(false)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  projectRequest ProjectRequest    @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)
  contractor     ContractorProfile @relation(fields: [contractorId], references: [id])
  invoice        Invoice?
  auditEvents    AuditEvent[]
  feedbacks      Feedback[]
}

model AuditEvent {
  id               String         @id @default(cuid())
  eventType        AuditEventType
  description      String
  metadata         Json?
  actorId          String?
  projectRequestId String?
  appointmentId    String?
  createdAt        DateTime       @default(now())

  actor          User?           @relation("AuditActor", fields: [actorId], references: [id])
  projectRequest ProjectRequest? @relation(fields: [projectRequestId], references: [id])
  appointment    Appointment?    @relation(fields: [appointmentId], references: [id])
}

model Dispute {
  id               String          @id @default(cuid())
  projectRequestId String          @unique
  contractorId     String
  status           DisputeStatus   @default(OPEN)
  outcome          DisputeOutcome?
  reason           String
  evidenceScore    Int             @default(0)
  resolutionNotes  String?
  isDemo           Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  projectRequest ProjectRequest    @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)
  contractor     ContractorProfile @relation(fields: [contractorId], references: [id])
}

model Invoice {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  contractorId  String
  amount        Float
  status        InvoiceStatus @default(PENDING)
  pilotProof    Boolean       @default(true)
  waivedReason  String?
  approvedById  String?
  approvedAt    DateTime?
  isDemo        Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  appointment Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  contractor  ContractorProfile @relation(fields: [contractorId], references: [id])
  approvedBy  User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
}

model Feedback {
  id            String   @id @default(cuid())
  appointmentId String
  actorType     String
  responses     Json
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model CaseStudy {
  id                 String          @id @default(cuid())
  projectRequestId   String          @unique
  trade              String
  zipCode            String
  leadSource         String?
  timingMetrics      Json?
  homeownerConfirmed Boolean         @default(false)
  contractorAttended Boolean         @default(false)
  estimateGiven      String?
  disputeOccurred    Boolean         @default(false)
  lessonsLearned     String?
  nextImprovement    String?
  status             CaseStudyStatus @default(DRAFT)
  createdAt          DateTime        @default(now())

  projectRequest ProjectRequest @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)
}

model ContractorInquiry {
  id              String   @id @default(cuid())
  companyName     String
  contactName     String
  phone           String
  email           String
  trade           String
  serviceZips     String
  yearsInBusiness Int?
  employeeCount   Int?
  licensedInsured Boolean  @default(false)
  usesLeadGen     Boolean  @default(false)
  avgJobSize      String?
  referralSource  String?
  // Cold-outreach prospect fields (populated by the DMV scraper import). These
  // carry through to the email merge context so bulk sends can personalize with
  // the prospect's city and review rating.
  city            String?
  state           String?
  rating          String?
  reviewCount     Int?
  website         String?
  source          String?
  status          String   @default("new")
  isDemo          Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([status])
  @@index([email])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwilioPhoneNumber {
  id             String   @id @default(cuid())
  phoneNumber    String   @unique
  label          String?
  assignedUserId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignedUser User?     @relation("AssignedAgentNumbers", fields: [assignedUserId], references: [id])
  callLogs     CallLog[]
}

model CallLog {
  id                  String    @id @default(cuid())
  twilioCallSid       String    @unique
  direction           String    @default("outbound")
  fromNumber          String
  toNumber            String
  status              String    @default("initiated")
  durationSeconds     Int?
  disposition         String?
  dispositionNote     String?
  agentId             String?
  twilioPhoneNumberId String?
  projectRequestId    String?
  contractorId        String?
  startedAt           DateTime  @default(now())
  endedAt             DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  agent             User?              @relation("AgentCalls", fields: [agentId], references: [id])
  twilioPhoneNumber TwilioPhoneNumber? @relation(fields: [twilioPhoneNumberId], references: [id])
  projectRequest    ProjectRequest?    @relation(fields: [projectRequestId], references: [id])
  contractor        ContractorProfile? @relation(fields: [contractorId], references: [id])
}

model EmailMessage {
  id                String   @id @default(cuid())
  sendgridMessageId String?
  fromEmail         String
  toEmail           String
  subject           String
  body              String
  status            String   @default("sent")
  // "outbound" for sends; "inbound" for replies captured via the SendGrid
  // Inbound Parse webhook. Inbound rows reuse this table so a prospect's replies
  // sit alongside our sends in the same communication timeline.
  direction         String   @default("outbound")
  // For an inbound reply, the id of the outbound EmailMessage it is replying to
  // (matched by sender address at parse time). Null for outbound and unmatched.
  replyToMessageId  String?
  agentId           String?
  projectRequestId  String?
  contractorId      String?
  campaignId        String?
  // Delivery lifecycle timestamps, populated by the SendGrid event webhook.
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  bouncedAt         DateTime?
  spamReportedAt    DateTime?
  unsubscribedAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  agent          User?              @relation("AgentEmails", fields: [agentId], references: [id])
  projectRequest ProjectRequest?    @relation(fields: [projectRequestId], references: [id])
  contractor     ContractorProfile? @relation(fields: [contractorId], references: [id])
  campaign       EmailCampaign?     @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([sendgridMessageId])
}

/**
 * A bulk outreach send to a resolved audience segment. Holds the template used,
 * the resolved filter, and running counters. Each recipient gets its own
 * EmailMessage row (campaignId back-reference) so bulk sends still appear in the
 * per-contact communication timeline.
 */
model EmailCampaign {
  id              String    @id @default(cuid())
  name            String
  audience        String
  subject         String
  bodyTemplate    String
  templateId      String?
  // JSON-encoded segment filter used to resolve recipients (trade, zips, status…).
  filters         Json?
  replyTo         String?
  status          String    @default("draft") // draft | sending | sent | failed
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  ownerAgentId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  owner    User?          @relation("CampaignOwner", fields: [ownerAgentId], references: [id])
  messages EmailMessage[]
}

/**
 * Addresses that must never receive email — unsubscribes, hard bounces, and
 * spam complaints. The segment resolver and bulk sender both filter against
 * this table. Populated by the public unsubscribe route and (phase 2) the
 * SendGrid event webhook.
 */
model EmailSuppression {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String // unsubscribe | bounce | complaint | manual
  createdAt DateTime @default(now())

  @@index([email])
}
