# Reference only — certbot --nginx usually writes SSL blocks into renovessa.com.conf automatically.
# Use this if you configure certificates manually (e.g. certbot certonly --webroot).

upstream renovessa_app {
    server 127.0.0.1:7090;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name renovessa.com www.renovessa.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name renovessa.com www.renovessa.com;

    ssl_certificate /etc/letsencrypt/live/renovessa.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/renovessa.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://renovessa_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
