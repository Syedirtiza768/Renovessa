DATABASE_URL="postgresql://renovessa:renovessa@db:5432/renovessa?schema=public"
AUTH_SECRET="change-me-to-a-long-random-string-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:7090"
PORT=7090

# First-job MVP wedge
FIRST_JOB_MODE=true
PILOT_TRADE=HVAC
PILOT_ZIP_CLUSTERS=22030,22031,22032,22033
PILOT_MIN_BUDGET=1000
PILOT_CONTRACTOR_ID=
NEXT_PUBLIC_OPS_PHONE=+1-XXX-XXX-XXXX
NEXT_PUBLIC_LANDING_HEADLINE=Need HVAC help in Fairfax?

# Twilio (agent calling) — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Voice SDK (browser softphone)
# Create an API Key at Twilio Console > Develop > API keys & tokens
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# TwiML App SID — create a TwiML App (Manage > Voice > TwiML Apps) and point its
# Voice Request URL to: <TWILIO_WEBHOOK_BASE_URL or NEXT_PUBLIC_APP_URL>/api/calls/connect
TWILIO_TWIML_APP_SID=
# Public HTTPS base Twilio can reach for webhooks (required for local softphone —
# use an ngrok/localtunnel URL). Leave unset in production (uses NEXT_PUBLIC_APP_URL).
TWILIO_WEBHOOK_BASE_URL=

# SendGrid (agent email) — https://app.sendgrid.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=ops@renovessa.com
SENDGRID_FROM_NAME=Renovessa Ops
