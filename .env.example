DATABASE_URL="postgresql://renovessa:renovessa@db:5432/renovessa?schema=public"
AUTH_SECRET="change-me-to-a-long-random-string-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:7090"
PORT=7090

# First-job MVP wedge
FIRST_JOB_MODE=true
PILOT_TRADE=HVAC
PILOT_ZIP_CLUSTERS=22030,22031,22032,22033
PILOT_MIN_BUDGET=1000
PILOT_CONTRACTOR_ID=
NEXT_PUBLIC_OPS_PHONE=+1-XXX-XXX-XXXX
NEXT_PUBLIC_LANDING_HEADLINE=Need HVAC help in Fairfax?

# Twilio (agent calling) — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Voice SDK (browser softphone)
# Create an API Key at Twilio Console > Develop > API keys & tokens
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# TwiML App SID — create a TwiML App (Manage > Voice > TwiML Apps) and point its
# Voice Request URL to: <TWILIO_WEBHOOK_BASE_URL or NEXT_PUBLIC_APP_URL>/api/calls/connect
TWILIO_TWIML_APP_SID=
# Public HTTPS base Twilio can reach for webhooks (required for local softphone —
# use an ngrok/localtunnel URL). Leave unset in production (uses NEXT_PUBLIC_APP_URL).
TWILIO_WEBHOOK_BASE_URL=

# OpenRouter (homepage AI advisor) — https://openrouter.ai/keys
# Server-side only. Powers the interactive advice widget in the hero.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
# Set to true to show the hero AI advisor widget (requires OPENROUTER_API_KEY).
NEXT_PUBLIC_AI_ADVISOR_ENABLED=false

# SendGrid (agent email) — https://app.sendgrid.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=ops@renovessa.com
SENDGRID_FROM_NAME=Renovessa Ops
# Reply-to for BULK campaign sends (shared inbox). Falls back to SENDGRID_FROM_EMAIL.
SENDGRID_REPLY_TO=ops@renovessa.com
# Physical mailing address shown in the CAN-SPAM footer of every bulk email (required for cold outreach).
MAILING_ADDRESS="Renovessa, 123 Main St, Fairfax, VA 22030"
# Secret used to sign one-click unsubscribe tokens. openssl rand -base64 32
UNSUBSCRIBE_SECRET=change-me-to-a-long-random-string
# Base64 public key from SendGrid's Signed Event Webhook (Settings > Mail Settings >
# Event Webhook). If unset, webhook signature verification is skipped (dev only).
SENDGRID_WEBHOOK_VERIFICATION_KEY=
